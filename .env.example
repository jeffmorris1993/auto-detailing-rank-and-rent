# =========================================================================
# Oakland County Mobile Detailing — environment variables
#
# Copy this file to `.env.local` for local development and set the same
# variables in Vercel (Project Settings → Environment Variables) for Preview
# and Production deployments.
#
# Never commit a populated `.env` / `.env.local`. The .gitignore allow-lists
# only `.env.example` (this file).
# =========================================================================

# ------- Public site URL --------------------------------------------------
# Used by metadata (canonical URLs, OG, JSON-LD, sitemap, robots).
# No trailing slash. In Vercel Production this should be the apex domain.
NEXT_PUBLIC_SITE_URL=https://oaklandcountymobiledetailing.com


# ------- Supabase ---------------------------------------------------------
# Found in Supabase Dashboard → Project Settings → API.
#
# NEXT_PUBLIC_SUPABASE_URL    : safe to expose, used by both client and server
# SUPABASE_SERVICE_ROLE_KEY   : SECRET. Bypasses RLS. SERVER-ONLY.
#                               Never prefix with NEXT_PUBLIC_. Never log it.
#                               Only used in lib/supabase/server.ts and
#                               app/actions/submit-lead.ts.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...REPLACE_ME


# =========================================================================
# Setup checklist
# =========================================================================
# 1. Run the migration in Supabase to create the `leads` table:
#    supabase/migrations/0001_create_leads.sql
#    Apply via Supabase CLI (`supabase db push`), the SQL editor in the
#    Supabase dashboard, or the Supabase MCP `apply_migration` tool.
#
# 2. Verify RLS is enabled and there are no anon policies — the server
#    action authenticates with the service role and bypasses RLS by design.
#
# 3. Add the same three env vars to Vercel for Preview and Production.
#
# 4. TODO (production hardening):
#    - Replace the in-memory rate limiter in app/actions/submit-lead.ts
#      with Upstash Redis / Vercel KV (Marketplace).
#    - Add Vercel BotID or Turnstile for stronger spam protection.
#    - Wire an email/Slack/Zapier notification when a row is inserted
#      (Supabase Database Webhook → endpoint).
